                </div>
            </div>
        </footer>

        <!-- Windows 11 Taskbar Dock Navigation -->
        <nav class="taskbar-dock">
            <div class="dock-container">
                <a href="#home" class="dock-item active" data-tab-link="home" aria-label="Home">
                    <span class="dock-tooltip">Home</span>
                    <svg viewBox="0 0 100 100" class="dock-icon">
                        <rect x="0" y="0" width="47" height="47" />
                        <rect x="53" y="0" width="47" height="47" />
                        <rect x="0" y="53" width="47" height="47" />
