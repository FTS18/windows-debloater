    .console-body::after {
        content: '_';
        animation: blink 1s step-end infinite;
        color: #ffffff;
    }

    @keyframes blink {
        from, to { color: transparent }
        50% { color: #ffffff }
    }

    .mesh-gradient {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
        filter: blur(85px);
        opacity: 0.85;
        transform: translate(calc(var(--mouse-x, 0px) * 0.2), calc(var(--mouse-y, 0px) * 0.2));
        transition: transform 0.8s cubic-bezier(0.15, 0.85, 0.35, 1);
    }

    .blob {
        position: absolute;
        border-radius: 50%;
        animation: float 20s infinite alternate ease-in-out;
    }

    .blob-1 {
        top: -10%;
        left: 10%;
        width: 350px;
        height: 350px;
        background: radial-gradient(circle, rgba(168, 85, 247, 0.3) 0%, rgba(0,0,0,0) 70%);
        animation-duration: 25s;
    }

    .blob-2 {
        bottom: -10%;
        right: 15%;
        width: 450px;
        height: 450px;
        background: radial-gradient(circle, rgba(59, 130, 246, 0.25) 0%, rgba(0,0,0,0) 70%);
        animation-duration: 30s;
        animation-delay: -5s;
    }

    .blob-3 {
        top: 20%;
        right: 30%;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(236, 72, 153, 0.22) 0%, rgba(0,0,0,0) 70%);
        animation-duration: 22s;
        animation-delay: -10s;
    }

    .grain-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0.12;
        pointer-events: none;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
        filter: invert(1);
        z-index: 1;
    }

    /* Decorative Windows Logos */
    .decor-windows {
        position: absolute;
        pointer-events: none;
        z-index: 1;
        transition: transform 0.15s cubic-bezier(0.1, 0.9, 0.2, 1);
        color: rgba(255, 255, 255, 0.15);
    }

    .decor-windows.left {
        width: 320px;
        height: 320px;
        top: 18%;
        left: -80px;
        transform: translate(calc(var(--mouse-x, 0px) * -0.03 - var(--scroll-offset, 0px)), calc(var(--mouse-y, 0px) * -0.03));
    }

    .decor-windows.right {
        width: 270px;
        height: 270px;
        top: 12%;
        right: -60px;
        transform: translate(calc(var(--mouse-x, 0px) * -0.03 + var(--scroll-offset, 0px)), calc(var(--mouse-y, 0px) * -0.03));
        opacity: 0.28;
    }

    .decor-emoji-img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        filter: saturate(0.85) drop-shadow(0 15px 30px rgba(0,0,0,0.4));
        user-select: none;
        pointer-events: none;
    }

    .decor-windows-inner {
        width: 100%;
        height: 100%;
        animation-duration: 20s;
        animation-timing-function: ease-in-out;
        animation-iteration-count: infinite;
    }

    .decor-windows.left .decor-windows-inner {
        transform: perspective(1000px) rotateY(40deg) rotateX(15deg) rotateZ(-12deg);
        animation-name: winZoomLeft;
    }

    .decor-windows.right .decor-windows-inner {
        transform: perspective(1000px) rotateY(-40deg) rotateX(15deg) rotateZ(12deg);
        animation-name: winZoomRight;
        animation-delay: -4s;
    }

    @keyframes winZoomLeft {
        0% {
            transform: perspective(1000px) rotateY(40deg) rotateX(15deg) rotateZ(-12deg) scale(0.96);
        }
        50% {
            transform: perspective(1000px) rotateY(36deg) rotateX(12deg) rotateZ(-10deg) scale(1.05);
        }
        100% {
            transform: perspective(1000px) rotateY(40deg) rotateX(15deg) rotateZ(-12deg) scale(0.96);
        }
    }

    @keyframes winZoomRight {
        0% {
            transform: perspective(1000px) rotateY(-40deg) rotateX(15deg) rotateZ(12deg) scale(0.96);
        }
        50% {
            transform: perspective(1000px) rotateY(-36deg) rotateX(12deg) rotateZ(10deg) scale(1.05);
        }
        100% {
            transform: perspective(1000px) rotateY(-40deg) rotateX(15deg) rotateZ(12deg) scale(0.96);
        }
    }

    @keyframes float {
        0% {
            transform: translate(0, 0) scale(1);
        }
        50% {
            transform: translate(30px, 20px) scale(1.08);
        }
        100% {
            transform: translate(-20px, -30px) scale(0.92);
        }
    }

    .hero-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 20px;
