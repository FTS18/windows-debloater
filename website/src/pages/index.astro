    .feature-icon svg {
        width: 16px;
        height: 16px;
    }

    .feature-card h3 {
        position: relative;
        z-index: 2;
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 8px;
    }

    .feature-card p {
        position: relative;
        z-index: 2;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.5;
    }

    .narrow-container {
        max-width: 680px;
        margin: 0 auto;
        padding: 80px 24px;
    }

    .page-title {
        font-size: 36px;
        font-weight: 700;
        letter-spacing: -1px;
        margin-bottom: 8px;
        text-align: center;
        background: linear-gradient(180deg, #ffffff 0%, #a3a3a3 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .page-subtitle {
        font-size: 15px;
