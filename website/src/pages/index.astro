        flex-direction: column;
        gap: 8px;
    }

    .toggle-card {
        background-color: #202020;
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 10px 14px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .toggle-details h4 {
        font-size: 11.5px;
        font-weight: 500;
        margin-bottom: 1px;
    }

    .toggle-details p {
        font-size: 9.5px;
