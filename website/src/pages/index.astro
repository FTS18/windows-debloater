        <script>
            function switchTab(tabId) {
                const tabs = document.querySelectorAll('.tab-content');
                const navLinks = document.querySelectorAll('[data-tab-link]');

                tabs.forEach(tab => {
                    tab.classList.remove('active');
                });

                navLinks.forEach(link => {
                    link.classList.remove('active');
                });

                const targetTab = document.getElementById(`tab-${tabId}`);
                if (targetTab) {
                    targetTab.classList.add('active');
                    window.scrollTo({
                        top: 0,
                        behavior: 'smooth'
                    });
                }

                navLinks.forEach(link => {
                    if (link.getAttribute('href') === `#${tabId}` || link.getAttribute('data-tab-link') === tabId) {
                        link.classList.add('active');
                    }
                });

                history.pushState(null, null, `#${tabId}`);
            }

            document.querySelectorAll('[data-tab-link]').forEach(element => {
                element.addEventListener('click', (e) => {
                    const tabId = element.getAttribute('data-tab-link');
                    switchTab(tabId);
                    e.preventDefault();
                });
            });

            window.addEventListener('DOMContentLoaded', () => {
                const hash = window.location.hash.substring(1);
                const validTabs = ['home', 'download', 'privacy', 'terms', 'support'];
                if (hash && validTabs.includes(hash)) {
                    switchTab(hash);
                } else {
                    switchTab('home');
                }
            });

            const mockupNavItems = document.querySelectorAll('.app-mockup .nav-item');
            const mockupPanels = document.querySelectorAll('.app-mockup .mockup-main');

            mockupNavItems.forEach(item => {
                item.addEventListener('click', () => {
                    mockupNavItems.forEach(nav => nav.classList.remove('active'));
                    item.classList.add('active');

                    mockupPanels.forEach(panel => panel.classList.add('hidden'));

                    const target = item.getAttribute('data-target');
                    const targetPanel = document.getElementById(`mockup-panel-${target}`);
                    if (targetPanel) {
                        targetPanel.classList.remove('hidden');
                    }
                });
            });

            const setupMockupSwitchGroup = (switchClass, scoreId, fillClass, baseScore) => {
                const switches = document.querySelectorAll(`.${switchClass}`);
                const scoreValText = document.getElementById(scoreId);
                const progressBarFill = document.querySelector(`.${fillClass}`);

                switches.forEach(sw => {
                    sw.addEventListener('click', () => {
                        sw.classList.toggle('active');
                        
                        let currentScore = baseScore;
                        switches.forEach(s => {
                            if (s.classList.contains('active')) {
                                currentScore += parseInt(s.getAttribute('data-points'));
                            }
                        });
                        
                        if (scoreValText) scoreValText.innerText = `${currentScore}%`;
                        if (progressBarFill) progressBarFill.style.width = `${currentScore}%`;
                    });
                });
            };

            setupMockupSwitchGroup('switch-tweaks', 'score-tweaks', 'fill-tweaks', 65);
            setupMockupSwitchGroup('switch-cleaner', 'score-cleaner', 'fill-cleaner', 40);
            setupMockupSwitchGroup('switch-manager', 'score-manager', 'fill-manager', 50);
            setupMockupSwitchGroup('switch-startup', 'score-startup', 'fill-startup', 70);

            const copyBtn = document.getElementById('btn-copy');
            if (copyBtn) {
                copyBtn.addEventListener('click', () => {
                    const code = document.getElementById('cli-code').innerText;
                    navigator.clipboard.writeText(code).then(() => {
                        const copyIcon = copyBtn.querySelector('.icon-copy');
                        const checkIcon = copyBtn.querySelector('.icon-check');
                        
                        copyIcon.classList.add('hidden');
                        checkIcon.classList.remove('hidden');
                        copyBtn.classList.add('success');
                        
                        setTimeout(() => {
                            copyIcon.classList.remove('hidden');
                            checkIcon.classList.add('hidden');
                            copyBtn.classList.remove('success');
                        }, 2000);
                    });
                });
            }
            const featureCards = document.querySelectorAll('.feature-card');
            featureCards.forEach(card => {
                card.style.setProperty('--mouse-x', '0px');
                card.style.setProperty('--mouse-y', '0px');
                card.addEventListener('mousemove', (e) => {
                    const rect = card.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;
                    card.style.setProperty('--mouse-x', `${x}px`);
                    card.style.setProperty('--mouse-y', `${y}px`);
                });
            });

            const faqItems = document.querySelectorAll('.faq-item');
            faqItems.forEach(item => {
                const trigger = item.querySelector('.faq-trigger');
                const content = item.querySelector('.faq-content');
                
                if (trigger && content) {
                    trigger.addEventListener('click', () => {
                        const isActive = item.classList.contains('active');
                        
                        faqItems.forEach(otherItem => {
                            if (otherItem !== item) {
                                otherItem.classList.remove('active');
                                const otherContent = otherItem.querySelector('.faq-content');
                                if (otherContent) {
                                    otherContent.style.maxHeight = '0px';
                                }
                                const otherTrigger = otherItem.querySelector('.faq-trigger');
                                if (otherTrigger) {
                                    otherTrigger.setAttribute('aria-expanded', 'false');
                                }
                            }
                        });
                        
                        if (isActive) {
                            item.classList.remove('active');
                            content.style.maxHeight = '0px';
                            trigger.setAttribute('aria-expanded', 'false');
                        } else {
                            item.classList.add('active');
                            content.style.maxHeight = `${content.scrollHeight}px`;
                            trigger.setAttribute('aria-expanded', 'true');
                        }
                    });
                }
            });
        </script>
    </body>
</html>

