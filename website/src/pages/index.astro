    }

    .download-header h2 {
        font-size: 28px;
        font-weight: 700;
    }

    .file-size {
        font-size: 14px;
        color: var(--muted);
        font-weight: 500;
    }

    .download-description {
        color: var(--muted);
        font-size: 13.5px;
