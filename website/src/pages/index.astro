    /* Windows Startup Intro Preloader */
    .windows-preloader {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: #000000;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        z-index: 999999;
        transition: opacity 0.6s cubic-bezier(0.85, 0, 0.15, 1), visibility 0.6s;
    }

    .preloader-logo {
        display: flex;
        flex-direction: column;
        align-items: center;
        transform: scale(0.85);
        opacity: 0;
        animation: logoIntro 1.2s cubic-bezier(0.1, 0.9, 0.2, 1) forwards;
    }

    .preloader-win-svg {
        width: 64px;
        height: 64px;
        color: #ffffff;
        fill: currentColor;
