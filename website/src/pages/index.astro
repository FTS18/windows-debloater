    .toggle-switch {
        width: 32px;
        height: 16px;
        border-radius: 8px;
        background-color: #333333;
        border: 1px solid var(--border);
        position: relative;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .toggle-switch::after {
        content: '';
        position: absolute;
        top: 2px;
        left: 2px;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background-color: #888888;
        transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .toggle-switch.active {
        background-color: var(--fg);
        border-color: var(--fg);
    }

    .toggle-switch.active::after {
        left: 18px;
        background-color: var(--bg);
    }

    .code-container {
        position: relative;
    }

    .btn-copy {
        position: absolute;
        top: 10px;
        right: 10px;
        width: 30px;
        height: 30px;
        border-radius: 4px;
        background-color: #0f0f0f;
        border: 1px solid var(--border);
        color: var(--muted);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.15s ease;
    }

    .btn-copy:hover {
        border-color: var(--border-hover);
        color: var(--fg);
        background-color: #141414;
    }

    .btn-copy.success {
        border-color: #ffffff;
        color: #ffffff;
    }

    .btn-copy svg {
        width: 14px;
        height: 14px;
    }

    .hidden {
        display: none !important;
    }

    @media (max-width: 1024px) {
        .decor-windows {
            display: none !important;
        }
    }

    @media (max-width: 768px) {
        .nav-links {
            display: none;
        }
        .hero-title {
            font-size: 36px;
        }
        .support-grid {
            grid-template-columns: 1fr;
        }
        .mockup-wrapper {
            display: none !important;
        }
