                <a href="#download" class="dock-item" data-tab-link="download" aria-label="Download App">
                    <span class="dock-tooltip">Download App</span>
                    <img src="/logo.png" class="dock-icon-img" alt="Download" />
                    <span class="dock-indicator"></span>
                </a>
                <a href="#privacy" class="dock-item" data-tab-link="privacy" aria-label="Privacy Policy">
                    <span class="dock-tooltip">Privacy Policy</span>
                    <svg viewBox="0 0 24 24" class="dock-icon outline" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                    <span class="dock-indicator"></span>
                </a>
                <a href="#terms" class="dock-item" data-tab-link="terms" aria-label="Terms of Service">
                    <span class="dock-tooltip">Terms of Service</span>
                    <svg viewBox="0 0 24 24" class="dock-icon outline" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                        <polyline points="10 9 9 9 8 9"/>
                    </svg>
                    <span class="dock-indicator"></span>
                </a>
                <a href="#support" class="dock-item" data-tab-link="support" aria-label="Customer Support">
                    <span class="dock-tooltip">Customer Support</span>
                    <svg viewBox="0 0 24 24" class="dock-icon outline" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/>
                        <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
                        <line x1="12" y1="17" x2="12.01" y2="17"/>
                    </svg>
                    <span class="dock-indicator"></span>
                </a>
            </div>
        </nav>

        <script>
            const preloaderStartTime = Date.now();

            function switchTab(tabId) {
                const tabs = document.querySelectorAll('.tab-content');
                const navLinks = document.querySelectorAll('[data-tab-link]');

                tabs.forEach(tab => {
                    tab.classList.remove('active');
                });

                navLinks.forEach(link => {
                    link.classList.remove('active');
                });

                const targetTab = document.getElementById(`tab-${tabId}`);
                if (targetTab) {
                    targetTab.classList.add('active');
                    window.scrollTo({
                        top: 0,
                        behavior: 'smooth'
                    });
                }

                navLinks.forEach(link => {
                    if (link.getAttribute('href') === `#${tabId}` || link.getAttribute('data-tab-link') === tabId) {
                        link.classList.add('active');
                    }
                });

                history.pushState(null, null, `#${tabId}`);
            }

            document.querySelectorAll('[data-tab-link]').forEach(element => {
                element.addEventListener('click', (e) => {
                    const tabId = element.getAttribute('data-tab-link');
                    switchTab(tabId);
                    e.preventDefault();
                });
            });

            window.addEventListener('DOMContentLoaded', () => {
                const hash = window.location.hash.substring(1);
                const validTabs = ['home', 'download', 'privacy', 'terms', 'support'];
                if (hash && validTabs.includes(hash)) {
                    switchTab(hash);
                } else {
                    switchTab('home');
                }
                setTimeout(() => {
                    if (typeof startConsoleTicker === 'function') startConsoleTicker();
                }, 1000);
            });

            // preloader startup transition (minimum 2 seconds)
            window.addEventListener('load', () => {
                const elapsedTime = Date.now() - preloaderStartTime;
                const remainingDelay = Math.max(0, 2000 - elapsedTime);
                
                setTimeout(() => {
                    const preloader = document.getElementById('preloader');
                    if (preloader) {
                        preloader.classList.add('fade-out');
                        setTimeout(() => {
                            preloader.style.display = 'none';
                        }, 800);
                    }
                }, remainingDelay);
            });

            // Watermarks scroll parallax exit effect
            window.addEventListener('scroll', () => {
                const scrollTop = window.scrollY;
                const offset = scrollTop * 0.45;
                document.documentElement.style.setProperty('--scroll-offset', `${offset}px`);
            });

            const mockupNavItems = document.querySelectorAll('.app-mockup .nav-item');
            const mockupPanels = document.querySelectorAll('.app-mockup .mockup-main');

            mockupNavItems.forEach(item => {
                item.addEventListener('click', () => {
                    mockupNavItems.forEach(nav => nav.classList.remove('active'));
                    item.classList.add('active');

                    mockupPanels.forEach(panel => panel.classList.add('hidden'));

                    const target = item.getAttribute('data-target');
                    const targetPanel = document.getElementById(`mockup-panel-${target}`);
                    if (targetPanel) {
                        targetPanel.classList.remove('hidden');
                    }

                    if (target === 'tweaks') {
                        if (typeof startConsoleTicker === 'function') startConsoleTicker();
                    } else {
                        if (typeof stopConsoleTicker === 'function') stopConsoleTicker();
                    }
                });
            });

            const setupMockupSwitchGroup = (switchClass, scoreId, fillClass, baseScore) => {
                const switches = document.querySelectorAll(`.${switchClass}`);
                const scoreValText = document.getElementById(scoreId);
                const progressBarFill = document.querySelector(`.${fillClass}`);
                const consoleBody = document.getElementById('console-body');

                switches.forEach(sw => {
                    sw.addEventListener('click', () => {
                        sw.classList.toggle('active');
                        
                        let currentScore = baseScore;
                        switches.forEach(s => {
                            if (s.classList.contains('active')) {
                                currentScore += parseInt(s.getAttribute('data-points'));
                            }
                        });
                        
                        if (scoreValText) scoreValText.innerText = `${currentScore}%`;
                        if (progressBarFill) progressBarFill.style.width = `${currentScore}%`;

                        // Append real-time logs when toggle status changes
                        if (consoleBody) {
                            const isActivated = sw.classList.contains('active');
                            const toggleDetailsNode = sw.parentElement.querySelector('h4');
                            if (toggleDetailsNode) {
                                const toggleName = toggleDetailsNode.innerText;
                                const timestamp = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false });
                                const logLine = document.createElement('div');
                                logLine.className = 'console-line ' + (isActivated ? 'success' : 'warn');
                                logLine.innerText = `[${timestamp}] ${isActivated ? 'SUCCESS - Applied' : 'INFO - Reverted'}: ${toggleName}`;
                                consoleBody.appendChild(logLine);
                                consoleBody.scrollTop = consoleBody.scrollHeight;
                            }
                        }
                    });
                });
            };

            setupMockupSwitchGroup('switch-tweaks', 'score-tweaks', 'fill-tweaks', 65);
            setupMockupSwitchGroup('switch-cleaner', 'score-cleaner', 'fill-cleaner', 40);
            setupMockupSwitchGroup('switch-manager', 'score-manager', 'fill-manager', 50);
            setupMockupSwitchGroup('switch-startup', 'score-startup', 'fill-startup', 70);

            const copyBtn = document.getElementById('btn-copy');
            if (copyBtn) {
                copyBtn.addEventListener('click', () => {
                    const code = document.getElementById('cli-code').innerText;
                    navigator.clipboard.writeText(code).then(() => {
                        const copyIcon = copyBtn.querySelector('.icon-copy');
                        const checkIcon = copyBtn.querySelector('.icon-check');
                        
                        copyIcon.classList.add('hidden');
                        checkIcon.classList.remove('hidden');
                        copyBtn.classList.add('success');
                        
                        setTimeout(() => {
                            copyIcon.classList.remove('hidden');
                            checkIcon.classList.add('hidden');
                            copyBtn.classList.remove('success');
                        }, 2000);
                    });
                });
            }
            const featureCards = document.querySelectorAll('.feature-card');
            featureCards.forEach(card => {
                card.style.setProperty('--mouse-x', '0px');
                card.style.setProperty('--mouse-y', '0px');
                card.addEventListener('mousemove', (e) => {
                    const rect = card.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;
                    card.style.setProperty('--mouse-x', `${x}px`);
                    card.style.setProperty('--mouse-y', `${y}px`);
                });
            });

            const faqItems = document.querySelectorAll('.faq-item');
            faqItems.forEach(item => {
                const trigger = item.querySelector('.faq-trigger');
                const content = item.querySelector('.faq-content');
                
                if (trigger && content) {
                    trigger.addEventListener('click', () => {
                        const isActive = item.classList.contains('active');
                        
                        faqItems.forEach(otherItem => {
                            if (otherItem !== item) {
                                otherItem.classList.remove('active');
                                const otherContent = otherItem.querySelector('.faq-content');
                                if (otherContent) {
                                    otherContent.style.maxHeight = '0px';
                                }
                                const otherTrigger = otherItem.querySelector('.faq-trigger');
                                if (otherTrigger) {
                                    otherTrigger.setAttribute('aria-expanded', 'false');
                                }
                            }
                        });
                        
                        if (isActive) {
                            item.classList.remove('active');
                            content.style.maxHeight = '0px';
                            trigger.setAttribute('aria-expanded', 'false');
                        } else {
                            item.classList.add('active');
                            content.style.maxHeight = `${content.scrollHeight}px`;
                            trigger.setAttribute('aria-expanded', 'true');
                        }
                    });
                }
            });

            // Hero Mousemove Magnet Effect
            const hero = document.querySelector('.hero');
            const meshGradient = document.querySelector('.mesh-gradient');
            if (hero && meshGradient) {
                hero.addEventListener('mousemove', (e) => {
                    const rect = hero.getBoundingClientRect();
                    const x = e.clientX - rect.left - (rect.width / 2);
                    const y = e.clientY - rect.top - (rect.height / 2);
                    meshGradient.style.setProperty('--mouse-x', `${x}px`);
                    meshGradient.style.setProperty('--mouse-y', `${y}px`);
                });
                
                hero.addEventListener('mouseleave', () => {
                    meshGradient.style.setProperty('--mouse-x', '0px');
                    meshGradient.style.setProperty('--mouse-y', '0px');
                });
            }

            // PowerShell Log Ticker
            const consoleBody = document.getElementById('console-body');
            let consoleTimeoutId = null;
            let logIndex = 0;
            const basePrompt = '<div class="console-line prompt">PS C:\\Users\\Admin&gt; <span class="typed-command">./ApexDebloater.exe --debloat</span></div>';
            
            const logs = [
                { text: "[INFO] Scanning system registries...", type: "info" },
                { text: "[INFO] Found 14 telemetry tasks.", type: "info" },
                { text: "[SUCCESS] Disabled: Customer Experience Program", type: "success" },
                { text: "[SUCCESS] Disabled: Compatibility Appraiser", type: "success" },
                { text: "[INFO] Scanning pre-installed packages...", type: "info" },
                { text: "[SUCCESS] Removed Package: Microsoft.BingNews", type: "success" },
                { text: "[SUCCESS] Removed Package: Microsoft.BingWeather", type: "success" },
                { text: "[SUCCESS] Disabled Windows Cortana background daemon.", type: "success" },
                { text: "[SUCCESS] Reclaimed 2.4 GB of system storage.", type: "success" },
                { text: "[SUCCESS] Reclaimed 1.1 GB of RAM.", type: "success" },
                { text: "[INFO] System optimization complete.", type: "info" },
                { text: "PS C:\\Users\\Admin> ", type: "prompt", isReset: true }
            ];

            function runTicker() {
                if (!consoleBody) return;
                
                if (logIndex < logs.length) {
                    const log = logs[logIndex];
                    const line = document.createElement('div');
                    line.className = `console-line ${log.type}`;
                    line.innerText = log.text;
                    consoleBody.appendChild(line);
                    
                    consoleBody.scrollTop = consoleBody.scrollHeight;
                    logIndex++;
                    
                    if (log.isReset) {
                        consoleTimeoutId = setTimeout(() => {
                            consoleBody.innerHTML = basePrompt;
                            logIndex = 0;
                            consoleTimeoutId = setTimeout(runTicker, 1500);
                        }, 5000);
                    } else {
                        consoleTimeoutId = setTimeout(runTicker, 800 + Math.random() * 800);
                    }
                }
            }

            window.startConsoleTicker = function() {
                if (consoleTimeoutId) {
                    clearTimeout(consoleTimeoutId);
                }
                if (consoleBody) {
                    consoleBody.innerHTML = basePrompt;
                }
                logIndex = 0;
                consoleTimeoutId = setTimeout(runTicker, 1000);
            };

            window.stopConsoleTicker = function() {
                if (consoleTimeoutId) {
                    clearTimeout(consoleTimeoutId);
                    consoleTimeoutId = null;
                }
            };
        </script>
    </body>
</html>

