<Window x:Class="ApexDebloater.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ApexDebloater"
        mc:Ignorable="d"
        Title="Settings" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource WindowBg}">

    <Window.Resources>
        <!-- Style for TabControl to hide its headers completely -->
        <Style x:Key="HiddenHeadersTabControl" TargetType="TabControl">
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/> <!-- Wider Windows 11 style Sidebar -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR PANEL (Windows 11 Settings Left Navigation Pane) -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBg}" 
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- User Profile Header -->
                    <RowDefinition Height="Auto"/> <!-- Search Bar -->
                    <RowDefinition Height="*"/>    <!-- Navigation list -->
                    <RowDefinition Height="Auto"/> <!-- Footer Theme Selector -->
                </Grid.RowDefinitions>

                <!-- User Profile Header (matches Windows 11 Settings profile card) -->
                <Grid Grid.Row="0" Margin="16,24,16,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Circular User Avatar -->
                    <Border Width="48" Height="48" CornerRadius="24" Background="{DynamicResource BorderBrush}" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Standard User Icon representation -->
                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource Text}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    
                    <!-- Name -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock x:Name="ProfileName" Text="User" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Text}" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>

                <!-- Settings Search Bar -->
                <Border Grid.Row="1" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Margin="16,0,16,16" Height="32">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="10,0,8,0"/>
                        <TextBox x:Name="SearchBox" Grid.Column="1" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Foreground="{DynamicResource Text}" FontSize="12" CaretBrush="{DynamicResource Text}" Width="190" HorizontalAlignment="Left" Padding="0" TextChanged="SearchBox_TextChanged"/>
                        <TextBlock x:Name="SearchPlaceholder" Grid.Column="1" IsHitTestVisible="False" Text="Find a setting" VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}" FontSize="12" Visibility="Visible"/>
                    </Grid>
                </Border>

                <!-- Windows 11 Navigation List (mdl2 icons) -->
                <ListBox Grid.Row="2" x:Name="Sidebar" Background="Transparent" BorderThickness="0" Margin="8,0" SelectedIndex="0">
                    <ListBoxItem Style="{StaticResource SidebarItem}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource Text}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Home" FontSize="12.5" Foreground="{DynamicResource Text}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>
                    </ListBoxItem>
                    
                    <ListBoxItem Style="{StaticResource SidebarItem}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE9E9;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource Text}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="System Tweaks" FontSize="12.5" Foreground="{DynamicResource Text}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>
                    </ListBoxItem>

                    <ListBoxItem Style="{StaticResource SidebarItem}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE95A;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource Text}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Disk Cleaner" FontSize="12.5" Foreground="{DynamicResource Text}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>
                    </ListBoxItem>

                    <ListBoxItem Style="{StaticResource SidebarItem}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource Text}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="App Manager" FontSize="12.5" Foreground="{DynamicResource Text}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>
                    </ListBoxItem>

                    <ListBoxItem Style="{StaticResource SidebarItem}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource Text}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Startup Apps" FontSize="12.5" Foreground="{DynamicResource Text}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>
                    </ListBoxItem>

                    <ListBoxItem Style="{StaticResource SidebarItem}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource Text}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Software Installer" FontSize="12.5" Foreground="{DynamicResource Text}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>
                    </ListBoxItem>

                    <ListBoxItem Style="{StaticResource SidebarItem}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource Text}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="System Repair" FontSize="12.5" Foreground="{DynamicResource Text}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>
                    </ListBoxItem>
                </ListBox>

                <!-- Sidebar Footer with Theme Toggle -->
                <Border Grid.Row="3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="16,12" Background="{DynamicResource SidebarBg}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Dark Mode Theme" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource Text}" FontWeight="Normal"/>
                        <ToggleButton Grid.Column="1" x:Name="ThemeToggle" Style="{StaticResource ToggleSwitch}" IsChecked="True" Checked="ThemeToggle_Checked" Unchecked="ThemeToggle_Unchecked"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- MAIN WINDOW CONTENT (Column 1 - Settings Page Area) -->
        <Grid Grid.Column="1">
            <TabControl SelectedIndex="{Binding SelectedIndex, ElementName=Sidebar}" Style="{StaticResource HiddenHeadersTabControl}">
                
                <!-- TAB 1: HOME/DASHBOARD -->
                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid Margin="40,30,40,30">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Page title -->
                                <RowDefinition Height="Auto"/> <!-- Device info ribbon -->
                                <RowDefinition Height="Auto"/> <!-- Primary optimization card -->
                                <RowDefinition Height="Auto"/> <!-- Quick stats -->
                                <RowDefinition Height="Auto"/> <!-- Status message -->
                            </Grid.RowDefinitions>

                            <!-- Title -->
                            <TextBlock Grid.Row="0" Text="System" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource Text}" Margin="0,0,0,18"/>

                            <!-- Device Ribbon (Matches Windows 11 Header Ribbon) -->
                            <Border Grid.Row="1" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Device Graphic Representation -->
                                    <Border Grid.Column="0" Width="60" Height="42" Background="{DynamicResource BorderBrush}" CornerRadius="2">
                                        <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource Text}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    
                                    <!-- Device Specs -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                                        <TextBlock x:Name="DeviceName" Text="Device" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                                        <TextBlock x:Name="DeviceModel" Text="Windows PC" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    
                                    <!-- Health Score -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,24,0">
                                        <Grid>
                                            <TextBlock Text="System Health" FontSize="11.5" Foreground="{DynamicResource TextMuted}"/>
                                            <TextBlock x:Name="HealthScoreText" Text="Loading..." FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <ProgressBar x:Name="HealthScoreBar" Value="0" Height="6" Background="{DynamicResource BorderBrush}" Foreground="{DynamicResource Accent}" BorderThickness="0" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    
                                    <!-- Elevated state badge -->
                                    <Border Grid.Column="3" Background="#10B981" CornerRadius="12" Padding="12,4" VerticalAlignment="Center">
                                        <TextBlock Text="Active (Elevated)" FontSize="11" Foreground="#1c1c1c" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- System Shield Card -->
                            <Border Grid.Row="2" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="20" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Restore Protection &amp; Safe Tweaks" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                                        <TextBlock Text="Automatically establish a secure backup point and configure Windows to recommended privacy and telemetry defaults." FontSize="11.5" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                                        <Button Content="Flush RAM Cache" Style="{StaticResource ModernButton}" Click="FlushRam_Click" Margin="0,0,8,0"/>
                                        <Button Content="Create Restore Point" Style="{StaticResource ModernButton}" Click="CreateRestore_Click" Margin="0,0,8,0"/>
                                        <Button Content="Run Optimization" Style="{StaticResource PrimaryButton}" Click="QuickOptimize_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Live Hardware Monitoring Panel -->
                            <Grid Grid.Row="3" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- CPU Monitor -->
                                <Border Grid.Column="0" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="16">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="CPU Load" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource Text}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" x:Name="CpuText" Text="0%" FontSize="13" Foreground="{DynamicResource Accent}" FontWeight="SemiBold" Margin="8,0,0,0"/>
                                        </Grid>
                                        <ProgressBar x:Name="CpuBar" Height="8" Minimum="0" Maximum="100" Value="0" Background="#262626" Foreground="{DynamicResource Accent}" BorderThickness="0" Margin="0,10,0,8"/>
                                        <TextBlock Text="Processor usage in real-time" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                    </StackPanel>
                                </Border>

                                <!-- RAM Monitor -->
                                <Border Grid.Column="2" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="16">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Memory (RAM)" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource Text}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" x:Name="RamText" Text="0.0 GB / 0.0 GB" FontSize="12.5" Foreground="{DynamicResource Accent}" FontWeight="SemiBold" Margin="8,0,0,0"/>
                                        </Grid>
                                        <ProgressBar x:Name="RamBar" Height="8" Minimum="0" Maximum="100" Value="0" Background="#262626" Foreground="{DynamicResource Accent}" BorderThickness="0" Margin="0,10,0,8"/>
                                        <TextBlock x:Name="RamSubtext" Text="0% utilized" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Storage Monitor -->
                                <Border Grid.Column="4" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="16">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="System Disk (C:)" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource Text}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" x:Name="StorageText" Text="0 GB Free" FontSize="12.5" Foreground="{DynamicResource Accent}" FontWeight="SemiBold" Margin="8,0,0,0"/>
                                        </Grid>
                                        <ProgressBar x:Name="StorageBar" Height="8" Minimum="0" Maximum="100" Value="0" Background="#262626" Foreground="{DynamicResource Accent}" BorderThickness="0" Margin="0,10,0,8"/>
                                        <TextBlock x:Name="StorageSubtext" Text="0 GB of 0 GB used" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <TextBlock Grid.Row="4" x:Name="DashboardStatusText" Text="System Status: Ready." FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,16,0,0"/>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <!-- TAB 2: SYSTEM TWEAKS -->
                <TabItem>
                    <Grid Margin="40,30,40,30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Header -->
                            <RowDefinition Height="*"/>    <!-- Tweaks List -->
                            <RowDefinition Height="Auto"/> <!-- Apply button -->
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="System Tweaks" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                            <TextBlock Text="Fine-tune your Windows environment. Turn toggles ON to apply, OFF to revert." FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- ItemsControl styled as Windows 11 settings cards list -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="TweaksItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Flat settings sub-card border -->
                                        <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/> <!-- Icon -->
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- Category Badge Icon (Generic MDL2) -->
                                                <TextBlock Grid.Column="0" Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                                
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                                                        <Border Background="#1A60CDFF" CornerRadius="2" Padding="4,1" Margin="8,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Risk}" FontSize="9" Foreground="{DynamicResource Accent}" FontWeight="SemiBold"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Description}" FontSize="11.5" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                </StackPanel>
                                                
                                                <ToggleButton Grid.Column="2" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding IsApplied, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Grid Grid.Row="2" Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Restore Registry Backups" Style="{StaticResource ModernButton}" Height="34" Width="180" HorizontalAlignment="Left" Click="RestoreBackups_Click"/>
                            <Button Grid.Column="1" Content="Apply Changes" Style="{StaticResource PrimaryButton}" Height="34" Width="130" HorizontalAlignment="Right" Click="ApplyTweaks_Click"/>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- TAB 3: DISK CLEANER -->
                <TabItem>
                    <Grid Margin="40,30,40,30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Header -->
                            <RowDefinition Height="*"/>    <!-- Options List -->
                            <RowDefinition Height="130"/>  <!-- Green Console -->
                            <RowDefinition Height="Auto"/> <!-- Run Button -->
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="Disk Cleaner" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                            <TextBlock Text="Select system caches and folders to clean up temporary space." FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Options Cards list -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,12">
                            <StackPanel>
                                <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,4">
                                    <CheckBox x:Name="CleanUserTemp" Style="{StaticResource ModernCheckBox}" IsChecked="True">
                                        <StackPanel Margin="6,0,0,0">
                                            <TextBlock Text="User Temporary Cache (%temp%)" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                                            <TextBlock Text="Clean log directories, diagnostic outputs, and app crash artifacts from your user profile." FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </CheckBox>
                                </Border>

                                <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,4">
                                    <CheckBox x:Name="CleanSystemTemp" Style="{StaticResource ModernCheckBox}" IsChecked="True">
                                        <StackPanel Margin="6,0,0,0">
                                            <TextBlock Text="System Temporary Folder (C:\Windows\Temp)" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                                            <TextBlock Text="Removes generic temp records written by system services and standard programs." FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </CheckBox>
                                </Border>

                                <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,4">
                                    <CheckBox x:Name="CleanPrefetch" Style="{StaticResource ModernCheckBox}" IsChecked="True">
                                        <StackPanel Margin="6,0,0,0">
                                            <TextBlock Text="Prefetch Data (C:\Windows\Prefetch)" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                                            <TextBlock Text="Safe cleanup of Windows pre-load optimization logs that accumulate over time." FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </CheckBox>
                                </Border>

                                <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,4">
                                    <CheckBox x:Name="CleanUpdates" Style="{StaticResource ModernCheckBox}" IsChecked="True">
                                        <StackPanel Margin="6,0,0,0">
                                            <TextBlock Text="Windows Update Downloads (SoftwareDistribution)" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                                            <TextBlock Text="Delete old cached Windows Update packages that are already applied (highly recommended)." FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </CheckBox>
                                </Border>

                                <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,4">
                                    <CheckBox x:Name="CleanRecycleBin" Style="{StaticResource ModernCheckBox}" IsChecked="True">
                                        <StackPanel Margin="6,0,0,0">
                                            <TextBlock Text="Empty Recycle Bin" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                                            <TextBlock Text="Permanently deletes files and folders currently in the system Recycle Bin." FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </CheckBox>
                                </Border>

                                <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,4">
                                    <CheckBox x:Name="CleanComponentStore" Style="{StaticResource ModernCheckBox}" IsChecked="False">
                                        <StackPanel Margin="6,0,0,0">
                                            <TextBlock Text="Windows Component Store (DISM Cleanup)" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                                            <TextBlock Text="Cleans and compresses obsolete Windows updates in the WinSxS directory (highly recommended; takes 1-2 mins)." FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </CheckBox>
                                </Border>

                                <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="16">
                                    <CheckBox x:Name="CleanDns" Style="{StaticResource ModernCheckBox}" IsChecked="True">
                                        <StackPanel Margin="6,0,0,0">
                                            <TextBlock Text="Flush DNS Cache" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                                            <TextBlock Text="Resets the local IP hostname cache, clearing routing bugs." FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </CheckBox>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Terminal console -->
                        <Border Grid.Row="2" Background="#1c1c1c" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,12">
                            <ScrollViewer x:Name="CleanerScroller" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <TextBlock x:Name="CleanerLogs" FontFamily="Consolas" FontSize="11" Foreground="#10B981" TextWrapping="Wrap" Text="Cleaner Console Ready. Click 'Run Cleaner' below."/>
                            </ScrollViewer>
                        </Border>

                        <Button Grid.Row="3" Content="Run Cleaner" Style="{StaticResource PrimaryButton}" Height="34" Width="130" HorizontalAlignment="Right" Click="RunCleaner_Click"/>
                    </Grid>
                </TabItem>

                <!-- TAB 4: APP MANAGER -->
                <TabItem>
                    <Grid Margin="40,30,40,30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Header -->
                            <RowDefinition Height="*"/>    <!-- Apps List -->
                            <RowDefinition Height="100"/>  <!-- Logs console -->
                            <RowDefinition Height="Auto"/> <!-- Buttons -->
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock x:Name="AppManagerTitle" Text="App Manager" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                            <TextBlock x:Name="AppManagerSubtitle" Text="Manage built-in Windows UWP Store bloatware or standard desktop applications." FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
                            
                            <!-- Sub-tab Selector -->
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <RadioButton x:Name="RadioStoreApps" Content="UWP Store Apps" Style="{StaticResource ModernTabRadioButton}" IsChecked="True" Checked="AppType_Changed"/>
                                <RadioButton x:Name="RadioDesktopApps" Content="Desktop Applications" Style="{StaticResource ModernTabRadioButton}" Checked="AppType_Changed"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Applications List Container -->
                        <Border Grid.Row="1" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,0,0,12">
                            <Grid>
                                <ListBox x:Name="AppxListBox" Background="Transparent" BorderThickness="0" Padding="8" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch" ScrollViewer.CanContentScroll="False">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="8,6" HorizontalAlignment="Stretch">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsChecked}" Style="{StaticResource ModernCheckBox}" VerticalAlignment="Center"/>
                                                    
                                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                            <TextBlock Text="{Binding Version}" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                                            <TextBlock Text="  •  " FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                                            <TextBlock Text="{Binding SizeMb}" FontSize="11" Foreground="{DynamicResource TextMuted}" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    
                                                    <Border Grid.Column="2" VerticalAlignment="Center" CornerRadius="2" Padding="6,2">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#1A7F7F7F"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRecommended}" Value="True">
                                                                        <Setter Property="Background" Value="#1AFF5F56"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock FontSize="10" FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="Installed App"/>
                                                                        <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsRecommended}" Value="True">
                                                                                <Setter Property="Text" Value="Recommended to Remove"/>
                                                                                <Setter Property="Foreground" Value="#FF5F56"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                <TextBlock x:Name="AppxPlaceholderText" Text="Click 'Scan for Bloatware' below to populate list." Foreground="{DynamicResource TextMuted}" IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13"/>
                            </Grid>
                        </Border>

                        <!-- Terminal console -->
                        <Border Grid.Row="2" Background="#1c1c1c" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,12">
                            <ScrollViewer x:Name="AppxScroller" VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="AppxLogs" FontFamily="Consolas" FontSize="11" Foreground="#10B981" TextWrapping="Wrap" Text="AppX Console Ready."/>
                            </ScrollViewer>
                        </Border>

                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="ScanAppsButton" Grid.Column="0" Content="Scan for Bloatware" Style="{StaticResource ModernButton}" Height="34" Click="ScanAppx_Click"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button x:Name="ReinstallAppsButton" Content="Reinstall Selected" Style="{StaticResource ModernButton}" Height="34" Width="140" Margin="0,0,10,0" Click="ReinstallAppx_Click"/>
                                <Button x:Name="UninstallAppsButton" Content="Uninstall Selected" Style="{StaticResource PrimaryButton}" Height="34" Width="140" Click="RemoveAppx_Click"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- TAB 5: STARTUP APPS -->
                <TabItem>
                    <Grid Margin="40,30,40,30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Header -->
                            <RowDefinition Height="*"/>    <!-- Startup Items List -->
                            <RowDefinition Height="Auto"/> <!-- Action bar -->
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="Startup Apps" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                            <TextBlock Text="Manage programs that run automatically on startup. Disable unnecessary apps to improve boot speed." FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Startup Items Container -->
                        <Border Grid.Row="1" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,0,0,12">
                            <Grid>
                                <ListBox x:Name="StandaloneStartupListBox" Background="Transparent" BorderThickness="0" Padding="8" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch" ScrollViewer.CanContentScroll="False" ItemContainerStyle="{StaticResource NoHighlightListBoxItem}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="8,6" HorizontalAlignment="Stretch">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                                                        <TextBlock Text="{Binding Command}" FontSize="10.5" Foreground="{DynamicResource TextMuted}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                            <TextBlock Text="{Binding Location}" FontSize="9.5" Foreground="{DynamicResource Accent}" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    
                                                    <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding IsEnabled}" Click="StandaloneStartupToggle_Click" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock x:Name="StandaloneStartupPlaceholderText" Text="Click 'Scan Startup Items' below to load." Foreground="{DynamicResource TextMuted}" IsHitTestVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2">
                            <Button Content="Scan Startup Items" Style="{StaticResource ModernButton}" Height="34" Width="150" HorizontalAlignment="Left" Click="ScanStandaloneStartup_Click"/>
                        </Grid>
                    </Grid>
                </TabItem>

                 <!-- TAB 6: SOFTWARE INSTALLER -->
                <TabItem>
                    <Grid Margin="40,30,40,30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Header -->
                            <RowDefinition Height="Auto"/> <!-- Warning Banner -->
                            <RowDefinition Height="*"/>    <!-- Software checklist -->
                            <RowDefinition Height="100"/>  <!-- Console -->
                            <RowDefinition Height="Auto"/> <!-- Button -->
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Software Installer" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                                <TextBlock Text="Install essential Windows utilities silently in the background using winget." FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
                            </StackPanel>
                            
                            <!-- Search Bar for Software -->
                            <Border Grid.Column="1" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Height="32" VerticalAlignment="Bottom">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="10,0,8,0"/>
                                    <TextBox Grid.Column="1" x:Name="SoftwareSearchBox" Background="Transparent" BorderThickness="0" VerticalAlignment="Stretch" VerticalContentAlignment="Center" Foreground="{DynamicResource Text}" FontSize="12" CaretBrush="{DynamicResource Text}" Padding="0" Margin="0,0,10,0" TextChanged="SoftwareSearchBox_TextChanged"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Winget Warning Banner -->
                        <Border x:Name="WingetWarningBanner" Grid.Row="1" Background="#1AFF5F56" BorderBrush="#FF5F56" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12" Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#FF5F56" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Winget is not installed or configured on your system PATH. Software search and installation features are disabled." FontSize="12" Foreground="#FF5F56" FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Software UniformGrid of Cards -->
                        <Border Grid.Row="2" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                            <Grid>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl x:Name="SoftwareItemsControl">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="3" VerticalAlignment="Top"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource SidebarBg}" CornerRadius="4" Padding="10" Margin="6" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsChecked}" IsEnabled="{Binding IsNotInstalled}" Style="{StaticResource ModernCheckBox}" Tag="{Binding Id}" VerticalAlignment="Center">
                                                            <StackPanel Margin="6,0,0,0">
                                                                <TextBlock Text="{Binding Name}" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Text}" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding Id}" FontSize="10" Foreground="{DynamicResource TextMuted}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                        </CheckBox>
                                                        
                                                        <Border Grid.Column="1" VerticalAlignment="Center" Background="#1A10B981" CornerRadius="2" Padding="6,2" Visibility="{Binding InstalledVisibility}">
                                                            <TextBlock Text="Installed" FontSize="10" FontWeight="SemiBold" Foreground="#10B981"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                
                                <!-- Search Loading Indicator -->
                                <Grid x:Name="SoftwareSearchLoadingOverlay" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <ProgressBar Width="80" Height="4" IsIndeterminate="True" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Searching WinGet repository..." Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Terminal console -->
                        <Border Grid.Row="3" Background="#1c1c1c" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,12">
                            <ScrollViewer x:Name="WingetScroller" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <TextBlock x:Name="WingetLogs" FontFamily="Consolas" FontSize="11" Foreground="#10B981" TextWrapping="Wrap" Text="Winget Installer Console Ready."/>
                            </ScrollViewer>
                        </Border>

                        <Button x:Name="InstallButton" Grid.Row="4" Content="Install Selected Apps" Style="{StaticResource PrimaryButton}" Height="34" Width="160" HorizontalAlignment="Right" Click="InstallSoftware_Click"/>
                    </Grid>
                </TabItem>

                <!-- TAB 6: TOOLS & REPAIR -->
                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid Margin="40,30,40,30">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Header -->
                                <RowDefinition Height="Auto"/> <!-- SFC & DISM repair cards -->
                                <RowDefinition Height="Auto"/> <!-- Toolbox section -->
                                <RowDefinition Height="130"/>  <!-- Console logs -->
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                                <TextBlock Text="Tools &amp; Repair" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                                <TextBlock Text="Manage auto-start programs, clean context menus, and repair system component stores." FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <!-- SFC, DISM & Utilities repairs layout -->
                            <Grid Grid.Row="1" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="1.1*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- SFC card -->
                                <Border Grid.Column="0" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="14,16" Margin="0,0,8,0" VerticalAlignment="Top" Height="200">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="System File Checker (SFC)" FontSize="14.5" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                                        <TextBlock Grid.Row="1" Text="Scans and repairs corrupted or missing Windows system files." FontSize="11" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" Margin="0,8,0,16"/>
                                        <Button Grid.Row="2" Content="Run SFC scan" Style="{StaticResource PrimaryButton}" Height="32" Click="RunSfc_Click"/>
                                    </Grid>
                                </Border>

                                <!-- DISM card -->
                                <Border Grid.Column="1" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="14,16" Margin="8,0,8,0" VerticalAlignment="Top" Height="200">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="Image Servicing (DISM)" FontSize="14.5" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                                        <TextBlock Grid.Row="1" Text="Uses Windows Update servers to repair component store corruption." FontSize="11" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" Margin="0,8,0,16"/>
                                        <Button Grid.Row="2" Content="Run DISM restore" Style="{StaticResource PrimaryButton}" Height="32" Click="RunDism_Click"/>
                                    </Grid>
                                </Border>

                                <!-- Quick Utilities card -->
                                <Border Grid.Column="2" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="14,16" Margin="8,0,0,0" VerticalAlignment="Top" Height="200">
                                    <StackPanel>
                                        <TextBlock Text="Quick Utilities" FontSize="14.5" FontWeight="SemiBold" Foreground="{DynamicResource Text}" Margin="0,0,0,8"/>
                                        <Button Content="Create System Restore Point" Style="{StaticResource ModernButton}" Height="28" Margin="0,0,0,6" FontSize="11" Click="CreateRestorePoint_Click"/>
                                        <Button Content="Activate Ultimate Power Plan" Style="{StaticResource ModernButton}" Height="28" Margin="0,0,0,12" FontSize="11" Click="UnlockUltimatePerformance_Click"/>
                                        
                                        <TextBlock Text="DNS Speed &amp; Privacy Switcher" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Text}" Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="DnsComboBox" Grid.Column="0" Height="28" VerticalContentAlignment="Center" Background="{DynamicResource CardBg}" Foreground="{DynamicResource Text}" BorderBrush="{DynamicResource BorderBrush}" FontSize="11">
                                                <ComboBox.Resources>
                                                    <Style TargetType="ComboBoxItem">
                                                        <Setter Property="Background" Value="{DynamicResource CardBg}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource Text}"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Padding" Value="6,4"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource ControlHoverBg}"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource Text}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource Accent}"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ComboBox.Resources>
                                                <ComboBoxItem Content="Default (ISP DNS)" IsSelected="True"/>
                                                <ComboBoxItem Content="Cloudflare (1.1.1.1)"/>
                                                <ComboBoxItem Content="Google DNS (8.8.8.8)"/>
                                                <ComboBoxItem Content="Quad9 (9.9.9.9)"/>
                                            </ComboBox>
                                            <Button Content="Apply DNS" Grid.Column="1" Style="{StaticResource PrimaryButton}" Height="28" Width="70" Margin="8,0,0,0" FontSize="11" Click="ApplyDns_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Section 2: Advanced Toolbox -->
                            <Grid Grid.Row="2" Margin="0,0,0,16">
                                <!-- Context Menu Cleaner Card -->
                                <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="16">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="Context Menu Cleaner" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                                        <ListBox Grid.Row="1" x:Name="ShellExtensionsListBox" Background="Transparent" BorderThickness="0" Margin="0,8,0,8" MaxHeight="220" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch" ScrollViewer.CanContentScroll="False" ItemContainerStyle="{StaticResource NoHighlightListBoxItem}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}" Padding="4,6">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Name}" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Text}" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding FriendlyDescription}" FontSize="9.5" Foreground="{DynamicResource TextMuted}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                            <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding IsEnabled}" Click="ToggleShellExtension_Click" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        <Button Grid.Row="2" Content="Scan Shell Extensions" Style="{StaticResource ModernButton}" Height="32" Click="ScanShellExtensions_Click"/>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- Console logs -->
                            <Border Grid.Row="3" Background="#1c1c1c" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10">
                                <ScrollViewer x:Name="RepairScroller" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Height="100">
                                    <TextBlock x:Name="RepairLogs" FontFamily="Consolas" FontSize="11" Foreground="#10B981" TextWrapping="Wrap" Text="Maintenance Logs Ready."/>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Grid>
    </Grid>
</Window>
